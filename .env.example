# ==============================================================================
# Configurações de Ambiente para o Conversor PDF-to-Markdown
# Copie este arquivo para um arquivo chamado '.env' e configure seus caminhos.
# ==============================================================================

# Diretório contendo os arquivos PDF que você deseja processar
# Se deixado em branco, o script utilizará por padrão './pdf_entrada'
CONVERTER_INPUT_DIR=

# Diretório onde os arquivos Markdown estruturados serão gerados
# Se deixado em branco, o script utilizará por padrão './markdown_saida'
CONVERTER_OUTPUT_DIR=

# Número de threads paralelas rodando o Docling de forma concorrente
CONVERTER_WORKERS=4

# Caminho do arquivo físico onde os logs de execução serão registrados
CONVERTER_LOG_FILE=conversao.log

# Chave de API do Google AI Studio para geração de Skills (Opcional)
# Obtenha gratuitamente em: https://aistudio.google.com/
GEMINI_API_KEY=